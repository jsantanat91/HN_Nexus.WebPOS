@page
@model HN_Nexus.WebPOS.Pages.Inventory.KardexModel
@{
    ViewData["Title"] = "Kardex";
    var entradas = Model.Rows.Where(x => x.Type == "Entrada").Sum(x => x.Quantity);
    var salidas = Model.Rows.Where(x => x.Type == "Salida").Sum(x => x.Quantity);
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Kardex por producto y sucursal</h5></div>
    <div class="panel-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3"><label class="form-label">Sucursal</label><select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select></div>
            <div class="col-md-3"><label class="form-label">Producto</label><select asp-for="ProductId" asp-items="Model.Products" class="form-select"></select></div>
            <div class="col-md-2"><label class="form-label">Desde</label><input asp-for="From" type="date" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Hasta</label><input asp-for="To" type="date" class="form-control" /></div>
            <div class="col-md-2"><button class="btn btn-primary w-100">Consultar</button></div>
        </form>
        <form method="get" asp-page-handler="Export" class="mt-2 row g-2">
            <input type="hidden" name="BranchId" value="@Model.BranchId" />
            <input type="hidden" name="ProductId" value="@Model.ProductId" />
            <input type="hidden" name="From" value="@Model.From.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="To" value="@Model.To.ToString("yyyy-MM-dd")" />
            <div class="col-md-3"><button class="btn btn-save w-100">Exportar a Excel (CSV)</button></div>
        </form>
        <div class="cards-grid compact mt-3">
            <div class="kpi-card glass-card kpi-gradient kpi-blue"><div class="kpi-title">Movimientos</div><div class="kpi-value text-primary">@Model.Rows.Count</div><span class="badge-soft badge-info">Registros</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-green"><div class="kpi-title">Entradas</div><div class="kpi-value text-success">@entradas</div><span class="badge-soft badge-ok">Unidades</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-red"><div class="kpi-title">Salidas</div><div class="kpi-value text-danger">@salidas</div><span class="badge-soft badge-danger">Unidades</span></div>
        </div>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Movimientos</h5></div>
    <div class="panel-body">
        @if (Model.Rows.Count == 0)
        {
            <div class="text-muted">Sin movimientos para el filtro seleccionado.</div>
        }
        else
        {
            <div class="cards-grid">
                @foreach (var r in Model.Rows)
                {
                    <article class="product-card">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge-soft badge-info">@r.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="badge-soft @(r.Type == "Entrada" ? "badge-ok" : "badge-danger")">@r.Type @r.Quantity</span>
                        </div>
                        <div class="fw-semibold mb-1">@r.Reference</div>
                        <div class="d-flex gap-1 flex-wrap mb-2">
                            <span class="badge-soft badge-info">Origen: @(string.IsNullOrWhiteSpace(r.Source) ? "-" : r.Source)</span>
                            @if (!string.IsNullOrWhiteSpace(r.Actor))
                            {
                                <span class="badge-soft badge-warn">Usuario: @r.Actor</span>
                            }
                            @if (r.UnitPrice.HasValue)
                            {
                                <span class="badge-soft badge-info">Precio: @r.UnitPrice.Value.ToString("C")</span>
                            }
                            @if (r.LineTotal.HasValue)
                            {
                                <span class="badge-soft badge-ok">Importe: @r.LineTotal.Value.ToString("C")</span>
                            }
                        </div>
                        <div class="product-meta">Detalle: @r.Notes</div>
                    </article>
                }
            </div>
        }
    </div>
</section>
