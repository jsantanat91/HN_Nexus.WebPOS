@page
@model HN_Nexus.WebPOS.Pages.Inventory.LotsModel
@{
    ViewData["Title"] = "Lotes y Caducidades";
}

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Control de lotes / series / caducidad</h5>
    </div>
    <div class="panel-body">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Sucursal</label>
                <select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select>
            </div>
            <div class="col-md-5">
                <label class="form-label">Producto</label>
                <select asp-for="ProductId" asp-items="Model.Products" class="form-select"></select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</section>

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Alta de lote</h5>
    </div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <input type="hidden" name="branchId" value="@Model.BranchId" />
            <input type="hidden" name="productId" value="@Model.ProductId" />
            <div class="col-md-3"><input name="lotNumber" class="form-control" placeholder="Lote (ej. LT-240301)" required /></div>
            <div class="col-md-2"><input name="serialNumber" class="form-control" placeholder="Serie (opcional)" /></div>
            <div class="col-md-2"><input name="expirationDate" type="date" class="form-control" /></div>
            <div class="col-md-2"><input name="quantity" type="number" min="1" class="form-control" placeholder="Cantidad" required /></div>
            <div class="col-md-2"><input name="unitCost" type="number" step="0.01" min="0" class="form-control" placeholder="Costo unitario" /></div>
            <div class="col-md-1 d-flex align-items-center"><button class="btn btn-save w-100">Guardar</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h5 class="mb-0">Lotes registrados</h5>
    </div>
    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Sucursal</th>
                    <th>Lote</th>
                    <th>Serie</th>
                    <th>Caducidad</th>
                    <th>Cantidad</th>
                    <th>Costo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var days = item.ExpirationDate.HasValue ? (item.ExpirationDate.Value.Date - DateTime.UtcNow.Date).TotalDays : 9999;
                    var badge = !item.ExpirationDate.HasValue ? "badge-info" : (days < 0 ? "badge-danger" : days <= 30 ? "badge-warning" : "badge-ok");
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.Branch?.Name</td>
                        <td><span class="badge-soft badge-info">@item.LotNumber</span></td>
                        <td>@(string.IsNullOrWhiteSpace(item.SerialNumber) ? "-" : item.SerialNumber)</td>
                        <td>
                            <span class="badge-soft @badge">
                                @(item.ExpirationDate?.ToLocalTime().ToString("dd/MM/yyyy") ?? "Sin caducidad")
                            </span>
                        </td>
                        <td>
                            <form method="post" asp-page-handler="Adjust" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="branchId" value="@Model.BranchId" />
                                <input type="hidden" name="productId" value="@Model.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control form-control-sm" style="max-width:100px;" />
                                <button class="btn btn-sm btn-outline-primary">Ajustar</button>
                            </form>
                        </td>
                        <td>@item.UnitCost.ToString("C")</td>
                        <td></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

