@page
@model HN_Nexus.WebPOS.Pages.Config.UsersModel
@{
    ViewData["Title"] = "Usuarios y roles";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Crear usuario</h5></div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-3">
            <div class="col-md-3"><label class="form-label">Nombre completo</label><input asp-for="Input.FullName" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Usuario</label><input asp-for="Input.Username" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Contraseña</label><input asp-for="Input.Password" class="form-control" type="password" /></div>
            <div class="col-md-3"><label class="form-label">Perfil</label><select asp-for="Input.ProfileId" asp-items="Model.Profiles" class="form-select"></select></div>
            <div class="col-md-2"><label class="form-label">Tenant</label><select asp-for="Input.TenantId" asp-items="Model.Tenants" class="form-select"></select></div>
            <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input asp-for="Input.IsSuperUser" class="form-check-input" /><label asp-for="Input.IsSuperUser" class="form-check-label">SuperUser</label></div></div>

            <div class="col-12">
                <strong class="d-block mb-2">Sucursales visibles</strong>
                <div class="row g-2">
                    @foreach (var branch in Model.Branches)
                    {
                        <div class="col-md-3 col-sm-6">
                            <label class="form-check-label d-flex align-items-center gap-2 border rounded p-2">
                                <input class="form-check-input" type="checkbox" name="bra_@branch.Id" checked />
                                <span>@branch.Name</span>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12"><button class="btn btn-save">Crear usuario</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Usuarios creados</h5></div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var u in Model.Users)
            {
                var branchSet = Model.UserBranchMap.ContainsKey(u.Id) ? Model.UserBranchMap[u.Id] : new HashSet<int>();
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <strong>@u.FullName</strong>
                        <span class="badge-soft @(u.IsActive ? "badge-ok" : "badge-danger")">@(u.IsActive ? "Activo" : "Inactivo")</span>
                    </div>
                    <div class="product-meta mb-1">Usuario: @u.Username</div>
                    <div class="d-flex gap-1 flex-wrap mb-2">
                        <span class="badge-soft badge-info">@(u.IsSuperUser ? "SuperUser" : (u.PermissionProfile?.Name ?? u.Role))</span>
                        @if (u.Tenant is not null)
                        {
                            <span class="badge-soft badge-warn">@u.Tenant.Code</span>
                        }
                        @foreach (var b in Model.Branches.Where(x => branchSet.Contains(x.Id)).Take(3))
                        {
                            <span class="badge-soft category-pill" data-category="@b.Name">@b.Name</span>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUserModal-@u.Id">Editar</button>
                        @if (!u.Username.Equals("admin", StringComparison.OrdinalIgnoreCase) && u.IsActive)
                        {
                            <form method="post" asp-page-handler="Deactivate" class="d-inline">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-sm btn-cancel" onclick="return confirm('¿Desactivar usuario?');">Desactivar</button>
                            </form>
                        }
                    </div>
                </article>

                <div class="modal fade" id="editUserModal-@u.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header"><h5 class="modal-title">Editar usuario: @u.Username</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                            <form method="post" asp-page-handler="Edit">
                                <input type="hidden" name="id" value="@u.Id" />
                                <div class="modal-body">
                                    <div class="row g-2">
                                        <div class="col-md-5"><label class="form-label">Nombre completo</label><input class="form-control" name="fullName" value="@u.FullName" /></div>
                                        <div class="col-md-4"><label class="form-label">Perfil</label><select class="form-select" name="profileId">@foreach (var p in Model.Profiles){ var selected = u.PermissionProfileId.HasValue && u.PermissionProfileId.Value.ToString() == p.Value; <option value="@p.Value" selected="@selected">@p.Text</option>}</select></div>
                                        <div class="col-md-3"><label class="form-label">Tenant</label><select class="form-select" name="tenantId">@foreach (var t in Model.Tenants){ var tsel = u.TenantId.HasValue && u.TenantId.Value.ToString() == t.Value; <option value="@t.Value" selected="@tsel">@t.Text</option>}</select></div>
                                        <div class="col-md-3"><label class="form-label">Nueva contraseña</label><input class="form-control" type="password" name="password" placeholder="Opcional" /></div>
                                        <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input class="form-check-input" type="checkbox" name="isSuperUser" checked="@u.IsSuperUser" /><label class="form-check-label">SuperUser</label></div></div>

                                        <div class="col-12"><strong class="d-block mb-1">Sucursales visibles</strong></div>
                                        @foreach (var b in Model.Branches)
                                        {
                                            var checkedBranch = branchSet.Contains(b.Id);
                                            <div class="col-md-4"><label class="form-check-label d-flex align-items-center gap-2 border rounded p-2"><input class="form-check-input" type="checkbox" name="ebr_@b.Id" checked="@checkedBranch" /><span>@b.Name</span></label></div>
                                        }
                                    </div>
                                </div>
                                <div class="modal-footer"><button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-save">Guardar</button></div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
