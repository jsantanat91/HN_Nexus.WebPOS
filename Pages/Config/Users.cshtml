@page
@using HN_Nexus.WebPOS.Models
@model HN_Nexus.WebPOS.Pages.Config.UsersModel
@{
    ViewData["Title"] = "Usuarios y Roles";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Crear Usuario</h5></div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-3">
            <div class="col-md-3"><label class="form-label">Nombre completo</label><input asp-for="Input.FullName" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Usuario</label><input asp-for="Input.Username" class="form-control" /></div>
            <div class="col-md-2"><label class="form-label">Contraseña</label><input asp-for="Input.Password" class="form-control" type="password" /></div>
            <div class="col-md-2">
                <label class="form-label">Rol</label>
                <select asp-for="Input.Role" class="form-select">
                    <option value="Cajero">Cajero</option>
                    <option value="Admin">Administrador</option>
                </select>
            </div>

            <div class="col-12">
                <strong class="d-block mb-2">Módulos</strong>
                <div class="row g-2">
                    @foreach (var module in ModuleCatalog.Labels)
                    {
                        <div class="col-md-3 col-sm-6">
                            <label class="form-check-label d-flex align-items-center gap-2 border rounded p-2">
                                <input class="form-check-input" type="checkbox" name="mod_@module.Key" checked />
                                <span>@module.Value</span>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12">
                <strong class="d-block mb-2">Sucursales visibles</strong>
                <div class="row g-2">
                    @foreach (var branch in Model.Branches)
                    {
                        <div class="col-md-3 col-sm-6">
                            <label class="form-check-label d-flex align-items-center gap-2 border rounded p-2">
                                <input class="form-check-input" type="checkbox" name="bra_@branch.Id" checked />
                                <span>@branch.Name</span>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12"><button class="btn btn-primary">Crear usuario</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Usuarios creados</h5></div>
    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead><tr><th>Nombre</th><th>Usuario</th><th>Rol</th><th>Estatus</th><th></th></tr></thead>
            <tbody>
            @foreach (var u in Model.Users)
            {
                <tr>
                    <td>@u.FullName</td>
                    <td>@u.Username</td>
                    <td><span class="badge-soft badge-info">@u.Role</span></td>
                    <td><span class="badge-soft @(u.IsActive ? "badge-ok" : "badge-danger")">@(u.IsActive ? "Activo" : "Inactivo")</span></td>
                    <td>
                        <form method="post" asp-page-handler="Toggle" class="d-inline">
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm btn-outline-primary">Cambiar estatus</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
