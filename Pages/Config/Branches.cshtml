@page
@model HN_Nexus.WebPOS.Pages.Config.BranchesModel
@{
    ViewData["Title"] = "Sucursales";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Nueva Sucursal</h5></div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-2"><input asp-for="NewBranch.Code" class="form-control" placeholder="Código" /></div>
            <div class="col-md-4"><input asp-for="NewBranch.Name" class="form-control" placeholder="Nombre" /></div>
            <div class="col-md-4"><input asp-for="NewBranch.Address" class="form-control" placeholder="Dirección" /></div>
            <div class="col-md-2"><button class="btn btn-primary w-100">Guardar</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Listado de Sucursales</h5></div>
    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead><tr><th>Código</th><th>Nombre</th><th>Dirección</th><th>Estatus</th><th></th></tr></thead>
            <tbody>
            @foreach (var b in Model.Branches)
            {
                <tr>
                    <td>@b.Code</td>
                    <td class="fw-semibold">@b.Name</td>
                    <td>@b.Address</td>
                    <td><span class="badge-soft @(b.IsActive ? "badge-ok" : "badge-danger")">@(b.IsActive ? "Activa" : "Inactiva")</span></td>
                    <td>
                        <form method="post" asp-page-handler="Toggle" class="d-inline">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button class="btn btn-sm btn-outline-primary">Cambiar</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
