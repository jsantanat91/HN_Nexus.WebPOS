@page
@model HN_Nexus.WebPOS.Pages.Config.CategoriesModel
@{
    ViewData["Title"] = "Categorías";
}

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Nueva Categoría</h5>
    </div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-5">
                <label class="form-label">Nombre</label>
                <input asp-for="NewName" class="form-control" placeholder="Ej. Papelería" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-save w-100" type="submit">Guardar</button>
            </div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h5 class="mb-0">Listado de Categorías</h5>
    </div>
    <div class="panel-body">
        <div class="d-flex flex-wrap gap-2">
            @foreach (var item in Model.Items)
            {
                <form method="post" asp-page-handler="Rename" class="d-flex gap-2 align-items-center category-chip-form">
                    <input type="hidden" name="id" value="@item.Id" />
                    <span class="badge-soft badge-info">#@item.Id</span>
                    <input type="text" name="name" value="@item.Name" class="form-control form-control-sm" style="max-width:220px;" />
                    <button class="btn btn-sm btn-save" type="submit">Guardar</button>
                    <button class="btn btn-sm btn-cancel" type="submit" formaction="?handler=Delete" onclick="return confirm('¿Eliminar categoría?');">Eliminar</button>
                </form>
            }
        </div>
    </div>
</section>
