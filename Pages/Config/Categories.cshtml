@page
@model HN_Nexus.WebPOS.Pages.Config.CategoriesModel
@{
    ViewData["Title"] = "Categorías";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Nueva categoría</h5></div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-5"><label class="form-label">Nombre</label><input asp-for="NewName" class="form-control" placeholder="Ej. Papelería" /></div>
            <div class="col-md-3 d-flex align-items-end"><button class="btn btn-save w-100" type="submit">Guardar</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Listado de categorías</h5></div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">#@item.Id</span>
                        <span class="badge-soft category-pill" data-category="@item.Name">@item.Name</span>
                    </div>
                    <form method="post" asp-page-handler="Rename" class="d-flex gap-2 align-items-center mb-2">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="text" name="name" value="@item.Name" class="form-control form-control-sm" />
                        <button class="btn btn-sm btn-save" type="submit">Guardar</button>
                    </form>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-cancel" type="submit" onclick="return confirm('¿Eliminar categoría?');">Eliminar</button>
                    </form>
                </article>
            }
        </div>
    </div>
</section>
