@page
@model HN_Nexus.WebPOS.Pages.Config.PromotionsModel
@{
    ViewData["Title"] = "Promociones";
}

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Motor de promociones avanzadas</h5>
    </div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-3"><input name="name" class="form-control" placeholder="Nombre promoción" required /></div>
            <div class="col-md-2">
                <select name="ruleType" class="form-select">
                    <option value="ThreeForTwo">3x2</option>
                    <option value="HappyHourPercent">Por horario (%)</option>
                    <option value="ComboPrice">Combo precio fijo</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="branchId" class="form-select">
                    <option value="">Todas las sucursales</option>
                    @foreach (var b in Model.Branches)
                    {
                        <option value="@b.Value">@b.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2"><select name="productId" class="form-select"><option value="">Producto (opcional)</option>@foreach (var p in Model.Products){<option value="@p.Value">@p.Text</option>}</select></div>
            <div class="col-md-3"><input name="productIdsCsv" class="form-control" placeholder="Combo IDs (ej. 1,2,3)" /></div>

            <div class="col-md-2"><input name="buyQty" type="number" class="form-control" placeholder="Compra" value="3" /></div>
            <div class="col-md-2"><input name="payQty" type="number" class="form-control" placeholder="Paga" value="2" /></div>
            <div class="col-md-2"><input name="discountPercent" type="number" step="0.01" class="form-control" placeholder="% desc." /></div>
            <div class="col-md-2"><input name="comboPrice" type="number" step="0.01" class="form-control" placeholder="Precio combo" /></div>
            <div class="col-md-2"><input name="startTime" type="time" class="form-control" /></div>
            <div class="col-md-2"><input name="endTime" type="time" class="form-control" /></div>

            <div class="col-md-10"><input name="daysOfWeekCsv" class="form-control" placeholder="Días (0=Dom..6=Sab, ej. 1,2,3,4,5)" /></div>
            <div class="col-md-2"><button class="btn btn-save w-100">Guardar</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Promociones activas e históricas</h5></div>
    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Sucursal</th>
                    <th>Producto</th>
                    <th>Regla</th>
                    <th>Horario</th>
                    <th>Estatus</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td><span class="badge-soft badge-info">@item.RuleType</span></td>
                        <td>@(item.Branch?.Name ?? "Todas")</td>
                        <td>@(item.Product?.Name ?? "-")</td>
                        <td>
                            @if (item.RuleType == "ThreeForTwo")
                            {
                                <span>@item.BuyQty x @item.PayQty</span>
                            }
                            else if (item.RuleType == "HappyHourPercent")
                            {
                                <span>@item.DiscountPercent %</span>
                            }
                            else
                            {
                                <span>Combo @item.ComboPrice.ToString("C") (@item.ProductIdsCsv)</span>
                            }
                        </td>
                        <td>@(item.StartTime?.ToString("HH:mm") ?? "--") - @(item.EndTime?.ToString("HH:mm") ?? "--")</td>
                        <td><span class="badge-soft @(item.IsActive ? "badge-ok" : "badge-danger")">@(item.IsActive ? "Activa" : "Inactiva")</span></td>
                        <td>
                            <form method="post" asp-page-handler="Toggle">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="branchId" value="@Model.BranchId" />
                                <button class="btn btn-sm btn-outline-primary">Cambiar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

