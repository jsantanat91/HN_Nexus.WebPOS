@page
@model HN_Nexus.WebPOS.Pages.Config.PromotionsModel
@{
    ViewData["Title"] = "Promociones";
    var active = Model.Items.Count(x => x.IsActive);
    var inactive = Model.Items.Count(x => !x.IsActive);
    var expiring = Model.Items.Count(x => x.IsActive && x.EndTime.HasValue);
}

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Motor de promociones</h5>
        <button class="btn btn-save" type="button" data-bs-toggle="modal" data-bs-target="#newPromoModal">Nueva promocion</button>
    </div>
    <div class="panel-body">
        <div class="cards-grid compact">
            <div class="kpi-card glass-card kpi-gradient kpi-blue"><div class="kpi-title">Total promociones</div><div class="kpi-value text-primary">@Model.Items.Count</div><span class="badge-soft badge-info">Configuradas</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-green"><div class="kpi-title">Activas</div><div class="kpi-value text-success">@active</div><span class="badge-soft badge-ok">Vigentes</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-amber"><div class="kpi-title">Con horario</div><div class="kpi-value text-warning">@expiring</div><span class="badge-soft badge-warn">Por ventana</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-red"><div class="kpi-title">Inactivas</div><div class="kpi-value text-danger">@inactive</div><span class="badge-soft badge-danger">Pausadas</span></div>
        </div>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Promociones activas e historicas</h5></div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">@item.RuleType</span>
                        <span class="badge-soft @(item.IsActive ? "badge-ok" : "badge-danger")">@(item.IsActive ? "Activa" : "Inactiva")</span>
                    </div>
                    <div class="fw-semibold mb-1">@item.Name</div>
                    <div class="product-meta">Sucursal: @(item.Branch?.Name ?? "Todas")</div>
                    <div class="product-meta">Producto: @(item.Product?.Name ?? "-")</div>
                    <div class="d-flex gap-1 flex-wrap mt-2 mb-2">
                        @if (item.RuleType == "ThreeForTwo")
                        {
                            <span class="badge-soft badge-warn">@item.BuyQty x @item.PayQty</span>
                        }
                        else if (item.RuleType == "HappyHourPercent")
                        {
                            <span class="badge-soft badge-warn">@item.DiscountPercent %</span>
                        }
                        else
                        {
                            <span class="badge-soft badge-warn">Combo @item.ComboPrice.ToString("C")</span>
                            <span class="badge-soft badge-info">@item.ProductIdsCsv</span>
                        }
                        <span class="badge-soft badge-info">@(item.StartTime?.ToString("HH:mm") ?? "--") - @(item.EndTime?.ToString("HH:mm") ?? "--")</span>
                    </div>
                    <form method="post" asp-page-handler="Toggle">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="hidden" name="branchId" value="@Model.BranchId" />
                        <button class="btn btn-sm btn-outline-primary">Cambiar estatus</button>
                    </form>
                </article>
            }
        </div>
    </div>
</section>

<div class="modal fade" id="newPromoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Nueva promocion</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="post" asp-page-handler="Create" id="promoForm">
                <div class="modal-body row g-2">
                    <div class="col-md-4"><label class="form-label">Nombre</label><input name="name" class="form-control" required /></div>
                    <div class="col-md-3">
                        <label class="form-label">Tipo</label>
                        <select name="ruleType" id="ruleType" class="form-select">
                            <option value="ThreeForTwo">3x2</option>
                            <option value="HappyHourPercent">Por horario (%)</option>
                            <option value="ComboPrice">Combo precio fijo</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Sucursal</label>
                        <select name="branchId" class="form-select">
                            <option value="">Todas las sucursales</option>
                            @foreach (var b in Model.Branches)
                            {
                                <option value="@b.Value">@b.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Producto</label>
                        <select name="productId" class="form-select">
                            <option value="">Opcional</option>
                            @foreach (var p in Model.Products)
                            {
                                <option value="@p.Value">@p.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2 promo-3x2"><label class="form-label">Compra</label><input name="buyQty" type="number" class="form-control" value="3" /></div>
                    <div class="col-md-2 promo-3x2"><label class="form-label">Paga</label><input name="payQty" type="number" class="form-control" value="2" /></div>
                    <div class="col-md-2 promo-happy" style="display:none;"><label class="form-label">% descuento</label><input name="discountPercent" type="number" step="0.01" class="form-control" value="10" /></div>
                    <div class="col-md-3 promo-combo" style="display:none;"><label class="form-label">IDs productos combo</label><input name="productIdsCsv" class="form-control" placeholder="1,2,3" /></div>
                    <div class="col-md-2 promo-combo" style="display:none;"><label class="form-label">Precio combo</label><input name="comboPrice" type="number" step="0.01" class="form-control" /></div>

                    <div class="col-md-2 promo-happy" style="display:none;"><label class="form-label">Hora inicio</label><input name="startTime" type="time" class="form-control" /></div>
                    <div class="col-md-2 promo-happy" style="display:none;"><label class="form-label">Hora fin</label><input name="endTime" type="time" class="form-control" /></div>
                    <div class="col-md-4 promo-happy" style="display:none;"><label class="form-label">Dias</label><input name="daysOfWeekCsv" class="form-control" placeholder="1,2,3,4,5" /></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-save">Guardar</button></div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const ruleType = document.getElementById('ruleType');
  const sync = () => {
    const v = ruleType?.value || 'ThreeForTwo';
    document.querySelectorAll('.promo-3x2').forEach(x => x.style.display = v === 'ThreeForTwo' ? '' : 'none');
    document.querySelectorAll('.promo-happy').forEach(x => x.style.display = v === 'HappyHourPercent' ? '' : 'none');
    document.querySelectorAll('.promo-combo').forEach(x => x.style.display = v === 'ComboPrice' ? '' : 'none');
  };
  ruleType?.addEventListener('change', sync);
  sync();
})();
</script>
}

