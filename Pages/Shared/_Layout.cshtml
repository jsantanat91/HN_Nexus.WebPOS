@using System.Security.Claims
@using HN_Nexus.WebPOS.Models
<!DOCTYPE html>
<html lang="es-mx">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HN Nexus POS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    var modules = (User.FindFirstValue("modules") ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(x => x.ToLowerInvariant())
        .ToHashSet();

    bool has(string code) => User.IsInRole("Admin") || modules.Contains(code);

    <div class="app-shell">
        <aside class="app-sidebar" id="appSidebar">
            <div class="brand-wrap">
                <div class="brand-logo">POS</div>
                <div>
                    <div class="brand-title">HN Nexus</div>
                    <small class="brand-subtitle">Punto de Venta</small>
                </div>
            </div>

            <nav class="nav flex-column nav-menu">
                @if (has(ModuleCatalog.Dashboard)) { <a class="nav-link" asp-page="/Index">Inicio</a> }
                @if (has(ModuleCatalog.Sales)) { <a class="nav-link" asp-page="/Sales/New">Caja</a> }
                @if (has(ModuleCatalog.Sales)) { <a class="nav-link" asp-page="/Sales/Index">Historial de Ventas</a> }
                @if (has(ModuleCatalog.Products)) { <a class="nav-link" asp-page="/Products/Index">Productos</a> }
                @if (has(ModuleCatalog.Customers)) { <a class="nav-link" asp-page="/Customers/Index">Clientes</a> }
                @if (has(ModuleCatalog.Expenses)) { <a class="nav-link" asp-page="/Expenses/Index">Gastos</a> }
                @if (has(ModuleCatalog.CashCuts)) { <a class="nav-link" asp-page="/CashCuts/Index">Cortes Caja</a> }
                @if (has(ModuleCatalog.CashShifts)) { <a class="nav-link" asp-page="/CashShifts/Index">Turnos Caja</a> }
                @if (has(ModuleCatalog.SupplierOrders)) { <a class="nav-link" asp-page="/SupplierOrders/Index">Pedidos</a> }
                @if (has(ModuleCatalog.Reports)) { <a class="nav-link" asp-page="/Reports/Daily">Reportes</a> }

                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link" asp-page="/Config/Index">Configuración</a>
                    <a class="nav-link" asp-page="/Config/Users">Usuarios</a>
                    <a class="nav-link" asp-page="/Config/Branches">Sucursales</a>
                    <a class="nav-link" asp-page="/Config/Permissions">Permisos</a>
                    <a class="nav-link" asp-page="/Config/Categories">Categorías</a>
                    <a class="nav-link" asp-page="/Config/Suppliers">Proveedores</a>
                }
            </nav>

            <div class="mt-auto pt-3">
                <a class="btn btn-cancel w-100" asp-page="/Account/Logout">Cerrar sesión</a>
            </div>
        </aside>

        <div class="app-main">
            <header class="app-topbar">
                <button class="btn btn-sm btn-light d-lg-none" id="sidebarToggle" type="button">Menu</button>
                <div>
                    <h1 class="page-title mb-0">@ViewData["Title"]</h1>
                    <p class="page-subtitle mb-0">Control total de ventas, inventario, sucursales y caja</p>
                </div>
                <div class="user-chip">
                    <span class="role-badge">@User.FindFirstValue(ClaimTypes.Role)</span>
                    <strong>@User.Identity?.Name</strong>
                </div>
            </header>

            <main class="app-content">
                @if (TempData["Flash"] != null)
                {
                    <div class="alert app-alert">@TempData["Flash"]</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    <main class="auth-wrap">
        @RenderBody()
    </main>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

