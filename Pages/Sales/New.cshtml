@page
@model HN_Nexus.WebPOS.Pages.Sales.NewModel
@{
    ViewData["Title"] = "Caja";
}

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <form method="get" class="panel">
            <div class="panel-body row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Sucursal activa</label>
                    <select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select>
                </div>
                <div class="col-md-3"><button class="btn btn-primary w-100">Cambiar sucursal</button></div>
                <div class="col-md-5">
                    <label class="form-label">Escáner código de barras</label>
                    <input id="barcodeInput" class="form-control" placeholder="Escanea y Enter..." autocomplete="off" />
                </div>
            </div>
        </form>
    </div>
    <div class="col-lg-4">
        <div class="panel">
            <div class="panel-body">
                <div class="d-flex justify-content-between align-items-center mb-2"><strong>Accesos rápidos</strong></div>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#quickProductModal">+ Producto rápido</button>
                    <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#quickCustomerModal">+ Cliente rápido</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo producto rápido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="QuickProduct">
                <input type="hidden" asp-for="BranchId" />
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-md-6"><label class="form-label">Nombre</label><input asp-for="QuickProductName" class="form-control" placeholder="Nombre" /></div>
                        <div class="col-md-3"><label class="form-label">Código</label><input asp-for="QuickProductCode" class="form-control" placeholder="Código" /></div>
                        <div class="col-md-3"><label class="form-label">Precio</label><input asp-for="QuickProductPrice" type="number" step="0.01" class="form-control" placeholder="Precio" /></div>
                        <div class="col-md-3"><label class="form-label">Stock</label><input asp-for="QuickProductStock" type="number" class="form-control" placeholder="Stock" /></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-cancel" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-save" type="submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo cliente rápido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="QuickCustomer">
                <input type="hidden" asp-for="BranchId" />
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-12"><label class="form-label">Nombre del cliente</label><input asp-for="QuickCustomerName" class="form-control" placeholder="Nombre cliente" /></div>
                        <div class="col-12"><label class="form-label">RFC</label><input asp-for="QuickCustomerRfc" class="form-control text-uppercase" placeholder="RFC" style="text-transform:uppercase;" /></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-cancel" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-save" type="submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<form method="post" class="pos-grid" id="posForm" data-tax="@Model.Config.TaxRate.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-currency="@Model.Config.CurrencySymbol">
    <input type="hidden" asp-for="BranchId" />

    <section class="panel">
        <div class="panel-header">
            <div>
                <h5 class="mb-0">Caja dinámica</h5>
                <small class="text-muted">Atajos: F2 buscar, + suma, - resta, F4 cobrar</small>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="Buscar producto..." style="width:220px;" />
                <span class="badge-soft badge-info">@Model.Products.Count productos</span>
            </div>
        </div>
        <div class="panel-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Cliente</label>
                    <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select">
                        <option value="">Público general</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Método de pago</label>
                    <select asp-for="PaymentMethod" class="form-select" id="paymentMethod">
                        <option value="Cash">Efectivo</option>
                        <option value="Card">Tarjeta</option>
                        <option value="Transfer">Transferencia</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Monto recibido</label>
                    <input asp-for="AmountReceived" id="amountReceived" type="number" step="0.01" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Descuento global (%)</label>
                    <input asp-for="GlobalDiscountPercent" id="globalDiscountPercent" type="number" min="0" max="100" step="0.01" class="form-control" value="0" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input class="form-check-input" asp-for="IsInvoice" />
                        <label class="form-check-label" asp-for="IsInvoice">Requiere factura CFDI</label>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input class="form-check-input" asp-for="PricesIncludeTax" id="pricesIncludeTax" />
                        <label class="form-check-label" asp-for="PricesIncludeTax">Precios ya incluyen IVA</label>
                    </div>
                </div>
                <div class="col-md-4" id="authCodeWrap" style="display:none;">
                    <label class="form-label">No. autorización tarjeta</label>
                    <input asp-for="AuthorizationCode" id="authorizationCode" class="form-control" placeholder="Número de autorización" />
                </div>
            </div>

            <div class="products-grid" id="productsGrid">
                @foreach (var item in Model.Products)
                {
                    <article class="product-card" data-price="@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-name="@item.Name.ToLowerInvariant()" data-code="@item.Barcode.ToLowerInvariant()" data-price-includes-tax="@item.PriceIncludesTax" data-product-id="@item.ProductId">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge-soft category-pill" data-category="@item.CategoryName">@item.CategoryName</span>
                            <span class="badge-soft @(item.Stock <= 3 ? "badge-danger" : "badge-ok")">Stock @item.Stock</span>
                        </div>
                        <div class="product-name">@item.Name</div>
                        <div class="product-meta mb-2">Cod: @item.Barcode</div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="price-chip">@item.Price.ToString("C")</span>
                            <div class="d-flex align-items-center gap-1">
                                <button class="btn btn-sm btn-outline-primary px-2 btn-dec" type="button">-</button>
                                <input type="number" min="0" max="@item.Stock" class="form-control qty-input" name="qty_@item.ProductId" value="0" data-product-id="@item.ProductId" />
                                <button class="btn btn-sm btn-outline-primary px-2 btn-inc" type="button">+</button>
                            </div>
                        </div>
                        <div class="mt-2">
                            <label class="form-label small mb-1">Desc. línea (%)</label>
                            <input type="number" min="0" max="100" step="0.01" class="form-control form-control-sm line-discount-input" name="disc_@item.ProductId" value="0" data-product-id="@item.ProductId" />
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h5 class="mb-0">Carrito y Cobro</h5>
                <small class="text-muted">Resumen de ticket en tiempo real</small>
            </div>
        </div>
        <div class="panel-body">
            <div id="cartRows" class="mb-3" style="max-height:260px; overflow:auto;"></div>

            <div class="ticket-preview mb-3">
                <div class="ticket-row"><span>Items</span><strong id="posItems">0</strong></div>
                <div class="ticket-row"><span>Subtotal</span><strong id="posSubtotal">$0.00</strong></div>
                <div class="ticket-row"><span>Descuentos</span><strong id="posDiscount">$0.00</strong></div>
                <div class="ticket-row"><span>IVA (@Model.Config.TaxRate%)</span><strong id="posIva">$0.00</strong></div>
                <hr />
                <div class="ticket-row ticket-total"><span>Total</span><span id="posTotal">$0.00</span></div>
                <div class="ticket-row"><span>Recibido</span><strong id="posReceived">$0.00</strong></div>
                <div class="ticket-row"><span>Cambio</span><strong id="posChange">$0.00</strong></div>
            </div>

            <div class="d-grid gap-2">
                <button class="btn btn-primary btn-lg" type="submit" id="btnCharge">Terminar venta (F4)</button>
                <a class="btn btn-outline-primary" asp-page="/Sales/Index" asp-route-branchId="@Model.BranchId">Ver historial</a>
            </div>
            <small class="text-muted d-block mt-2">Impresión: al terminar podrás usar ticket HTML con Ctrl+P para impresora térmica.</small>
        </div>
    </section>
</form>

@if (Model.TicketSaleId.HasValue)
{
<div class="modal fade" id="saleTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ticket venta #@Model.TicketSaleId</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" style="height:80vh;">
                <iframe src="/Sales/Ticket/@Model.TicketSaleId" style="width:100%; height:100%; border:0;"></iframe>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script>
(() => {
  document.querySelectorAll('.category-pill').forEach((pill) => {
    const key = (pill.dataset.category || '').trim();
    const palette = [
      ['#dbeafe', '#1d4ed8', '#93c5fd'],
      ['#dcfce7', '#166534', '#86efac'],
      ['#fef3c7', '#92400e', '#fcd34d'],
      ['#fee2e2', '#991b1b', '#fca5a5'],
      ['#e0f2fe', '#0e7490', '#7dd3fc'],
      ['#ede9fe', '#5b21b6', '#c4b5fd']
    ];
    const idx = key.split('').reduce((acc, ch) => acc + ch.charCodeAt(0), 0) % palette.length;
    const [bg, fg, bd] = palette[idx];
    pill.style.backgroundColor = bg;
    pill.style.color = fg;
    pill.style.borderColor = bd;
  });

  const payment = document.getElementById('paymentMethod');
  const wrap = document.getElementById('authCodeWrap');
  const auth = document.getElementById('authorizationCode');

  function syncAuth() {
    const isCard = (payment?.value || '') === 'Card';
    if (wrap) wrap.style.display = isCard ? 'block' : 'none';
    if (auth) auth.required = isCard;
  }

  payment?.addEventListener('change', syncAuth);
  syncAuth();

  const modalEl = document.getElementById('saleTicketModal');
  if (modalEl) {
    const modal = new bootstrap.Modal(modalEl);
    modal.show();
  }
})();
</script>
}
