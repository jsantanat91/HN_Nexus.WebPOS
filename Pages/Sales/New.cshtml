@page
@model HN_Nexus.WebPOS.Pages.Sales.NewModel
@{
    ViewData["Title"] = "Caja";
}

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <form method="get" class="panel">
            <div class="panel-body row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Sucursal activa</label>
                    <select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Almacén</label>
                    <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select"></select>
                </div>
                <div class="col-md-2"><button class="btn btn-primary w-100">Aplicar</button></div>
                <div class="col-md-5">
                    <label class="form-label">Escáner código de barras</label>
                    <input id="barcodeInput" class="form-control" placeholder="Escanea y Enter..." autocomplete="off" />
                </div>
            </div>
        </form>
    </div>
    <div class="col-lg-4">
        <div class="panel">
            <div class="panel-body">
                <div class="d-flex justify-content-between align-items-center mb-2"><strong>Accesos rápidos</strong></div>
                <div class="d-grid gap-2">
                    <button class="btn btn-quick-product" type="button" data-bs-toggle="modal" data-bs-target="#quickProductModal">Producto rápido</button>
                    <button class="btn btn-quick-customer" type="button" data-bs-toggle="modal" data-bs-target="#quickCustomerModal">Cliente rápido</button>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <span id="offlineStatus" class="badge-soft badge-ok">En línea</span>
                    <span id="offlineQueueBadge" class="badge-soft badge-info">0 pendientes</span>
                </div>
                <div class="d-grid mt-2">
                    <button type="button" class="btn btn-outline-primary btn-sm" id="btnSyncOfflineQueue">Sincronizar ventas offline</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Finalizar venta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Cliente</label>
                        <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select" id="checkoutCustomerId">
                            <option value="">Público general</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-quick-customer w-100" type="button" data-bs-toggle="modal" data-bs-target="#quickCustomerModal">Cliente rápido</button>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Tipo de pago</label>
                        <select asp-for="PaymentMethod" class="form-select" id="checkoutPaymentMethod">
                            <option value="Cash">Efectivo</option>
                            <option value="Card">Tarjeta</option>
                            <option value="Transfer">Transferencia</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Monto recibido</label>
                        <input asp-for="AmountReceived" id="checkoutAmountReceived" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Descuento global (%)</label>
                        <input asp-for="GlobalDiscountPercent" id="checkoutGlobalDiscountPercent" type="number" min="0" max="100" step="0.01" class="form-control" value="0" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Referencia / autorización</label>
                        <input asp-for="AuthorizationCode" id="checkoutAuthorizationCode" class="form-control" placeholder="Tarjeta: autorización / Transferencia: referencia" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="IsInvoice" id="checkoutIsInvoice" />
                            <label class="form-check-label" asp-for="IsInvoice">Requiere factura</label>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="PricesIncludeTax" id="checkoutPricesIncludeTax" />
                            <label class="form-check-label" asp-for="PricesIncludeTax">Precios con IVA</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="ticket-preview mb-0">
                            <div class="ticket-row ticket-total"><span>Total</span><span id="checkoutTotal">$0.00</span></div>
                            <div class="ticket-row"><span>Cambio</span><strong id="checkoutChange">$0.00</strong></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-cancel" type="button" data-bs-dismiss="modal">Cancelar</button>
                <button class="btn btn-save" type="submit" id="btnSubmitSale">Confirmar y generar ticket</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="quickProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo producto rápido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="QuickProduct">
                <input type="hidden" asp-for="BranchId" />
                <input type="hidden" asp-for="WarehouseId" />
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-md-6"><label class="form-label">Nombre</label><input asp-for="QuickProductName" class="form-control" placeholder="Nombre" /></div>
                        <div class="col-md-3"><label class="form-label">Código</label><input asp-for="QuickProductCode" class="form-control" placeholder="Código" /></div>
                        <div class="col-md-3"><label class="form-label">Precio</label><input asp-for="QuickProductPrice" type="number" step="0.01" class="form-control" placeholder="Precio" /></div>
                        <div class="col-md-3"><label class="form-label">Stock</label><input asp-for="QuickProductStock" type="number" class="form-control" placeholder="Stock" /></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-cancel" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-save" type="submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="quickCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo cliente rápido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="QuickCustomer">
                <input type="hidden" asp-for="BranchId" />
                <input type="hidden" asp-for="WarehouseId" />
                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-md-8"><label class="form-label">Nombre del cliente</label><input asp-for="QuickCustomerName" class="form-control" placeholder="Nombre cliente" /></div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="QuickCustomerRequiresInvoice" id="quickRequiresInvoice" />
                                <label class="form-check-label" asp-for="QuickCustomerRequiresInvoice">Requiere factura</label>
                            </div>
                        </div>
                        <div class="col-md-4"><label class="form-label">RFC</label><input asp-for="QuickCustomerRfc" id="quickRfcInput" class="form-control text-uppercase" placeholder="RFC" style="text-transform:uppercase;" /></div>
                        <div class="col-md-4"><label class="form-label">Código postal</label><input asp-for="QuickCustomerPostalCode" id="quickCpInput" class="form-control" placeholder="00000" maxlength="5" /></div>
                        <div class="col-md-8"><label class="form-label">Email</label><input asp-for="QuickCustomerEmail" class="form-control" placeholder="correo@dominio.com" /></div>
                        <div id="quickInvoiceFields" class="row g-2">
                            <div class="col-md-6"><label class="form-label">Uso CFDI</label><select asp-for="QuickCustomerCfdiUse" asp-items="Model.QuickCfdiUses" class="form-select"></select></div>
                            <div class="col-md-6"><label class="form-label">Forma de pago SAT</label><select asp-for="QuickCustomerPaymentForm" asp-items="Model.QuickPaymentForms" class="form-select"></select></div>
                            <div class="col-md-6"><label class="form-label">Método de pago SAT</label><select asp-for="QuickCustomerPaymentMethodSat" asp-items="Model.QuickPaymentMethods" class="form-select"></select></div>
                            <div class="col-12"><small id="quickSatValidation" class="text-muted">Validación SAT en vivo: RFC y código postal.</small></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-cancel" type="button" data-bs-dismiss="modal">Cancelar</button>
                    <button class="btn btn-save" type="submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<form method="post" class="pos-grid" id="posForm" data-tax="@Model.Config.TaxRate.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-currency="@Model.Config.CurrencySymbol" data-offline-endpoint="?handler=OfflineSync">
    <input type="hidden" asp-for="BranchId" />
    <input type="hidden" asp-for="WarehouseId" />

    <section class="panel">
        <div class="panel-header">
            <div>
                <h5 class="mb-0">Caja dinámica</h5>
                <small class="text-muted">Atajos: F8 escáner, F2 buscar, + suma, - resta, Ctrl+Enter/F4 cobrar, Alt+P producto rápido, Alt+C cliente rápido</small>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <input type="text" id="productSearch" class="form-control form-control-sm" placeholder="Buscar producto..." style="width:220px;" />
                <span class="badge-soft badge-info">@Model.Products.Count productos</span>
            </div>
        </div>
        <div class="panel-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-12 d-flex align-items-center justify-content-between gap-2 flex-wrap">
                    <small class="text-muted">Carga productos al carrito y luego usa <strong>Terminar venta (F4)</strong> para cobrar.</small>
                    <button class="btn btn-outline-danger" type="button" id="btnClearCart">Limpiar carrito</button>
                </div>
            </div>

            <div class="products-grid" id="productsGrid">
                @if (Model.Products.Count == 0)
                {
                    <div class="alert app-alert w-100 mb-0">Esta sucursal no tiene productos asignados. Usa “Producto rápido” o asígnalos desde Inventario por sucursal.</div>
                }
                @foreach (var item in Model.Products)
                {
                    <article class="product-card" data-price="@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-name="@item.Name.ToLowerInvariant()" data-code="@item.Barcode.ToLowerInvariant()" data-price-includes-tax="@item.PriceIncludesTax" data-product-id="@item.ProductId" data-promo-type="@item.PromotionType" data-promo-value="@item.PromotionValue.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-promo-min="@item.PromotionMinQty">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge-soft category-pill" data-category="@item.CategoryName">@item.CategoryName</span>
                            <span class="badge-soft @(item.Stock <= 3 ? "badge-danger" : "badge-ok")">Stock @item.Stock</span>
                        </div>
                        @if (item.PromotionType == "TwoForOne")
                        {
                            <div class="mb-1"><span class="badge-soft badge-warn">Promo 2x1</span></div>
                        }
                        else if (item.PromotionType == "Volume")
                        {
                            <div class="mb-1"><span class="badge-soft badge-warn">@item.PromotionValue% desde @item.PromotionMinQty piezas</span></div>
                        }
                        <div class="product-name">@item.Name</div>
                        <div class="product-meta mb-2">Cod: @item.Barcode</div>
                        <div class="mb-2">
                            <span class="price-chip">@item.Price.ToString("C")</span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <button class="btn btn-sm btn-outline-primary px-2 btn-dec" type="button">-</button>
                            <input type="number" min="0" max="@item.Stock" class="form-control qty-input" name="qty_@item.ProductId" value="0" data-product-id="@item.ProductId" />
                            <button class="btn btn-sm btn-outline-primary px-2 btn-inc" type="button">+</button>
                        </div>
                        <div class="mt-2">
                            <label class="form-label small mb-1">Desc. línea (%)</label>
                            <input type="number" min="0" max="100" step="0.01" class="form-control form-control-sm line-discount-input" name="disc_@item.ProductId" value="0" data-product-id="@item.ProductId" />
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section class="panel">
        <div class="panel-header">
            <div>
                <h5 class="mb-0">Carrito y Cobro</h5>
                <small class="text-muted">Resumen de ticket en tiempo real</small>
            </div>
        </div>
        <div class="panel-body">
            <div id="cartRows" class="mb-3" style="max-height:260px; overflow:auto;"></div>

            <div class="ticket-preview mb-3">
                <div class="ticket-row"><span>Items</span><strong id="posItems">0</strong></div>
                <div class="ticket-row"><span>Subtotal</span><strong id="posSubtotal">$0.00</strong></div>
                <div class="ticket-row"><span>Descuentos</span><strong id="posDiscount">$0.00</strong></div>
                <div class="ticket-row"><span>IVA (@Model.Config.TaxRate%)</span><strong id="posIva">$0.00</strong></div>
                <hr />
                <div class="ticket-row ticket-total"><span>Total</span><span id="posTotal">$0.00</span></div>
                <div class="ticket-row"><span>Recibido</span><strong id="posReceived">$0.00</strong></div>
                <div class="ticket-row"><span>Cambio</span><strong id="posChange">$0.00</strong></div>
            </div>

            <div class="d-grid gap-2">
                <button class="btn btn-primary btn-lg" type="button" id="btnCharge" data-bs-toggle="modal" data-bs-target="#checkoutModal">Terminar venta (F4)</button>
                <a class="btn btn-outline-primary" asp-page="/Sales/Index" asp-route-branchId="@Model.BranchId">Ver historial</a>
            </div>
            <small class="text-muted d-block mt-2">Impresión: al terminar podrás usar ticket HTML con Ctrl+P para impresora térmica.</small>
        </div>
    </section>
</form>

@if (Model.TicketSaleId.HasValue)
{
<script>
(() => {
  const saleId = @Model.TicketSaleId.Value;
  const popup = window.open(`/Sales/Ticket/${saleId}?popup=true&autoprint=true`, `ticket_${saleId}`, "width=460,height=820,menubar=no,toolbar=no,location=no,status=no,resizable=yes,scrollbars=yes");
  if (!popup) {
    alert("No se pudo abrir la ventana del ticket. Habilita popups para este sitio.");
  }
  if (window.history && window.history.replaceState) {
    const cleanUrl = `/Sales/New?branchId=@Model.BranchId&warehouseId=@Model.WarehouseId`;
    window.history.replaceState({}, document.title, cleanUrl);
  }
})();
</script>
}

@section Scripts {
<script>
(() => {
  if (typeof window.paintCategoryPills === 'function') {
    window.paintCategoryPills();
  }

  const payment = document.getElementById('checkoutPaymentMethod');
  const auth = document.getElementById('checkoutAuthorizationCode');
  const amountReceived = document.getElementById('checkoutAmountReceived');
  const globalDiscountPercent = document.getElementById('checkoutGlobalDiscountPercent');
  const pricesIncludeTax = document.getElementById('checkoutPricesIncludeTax');
  const checkoutTotal = document.getElementById('checkoutTotal');
  const checkoutChange = document.getElementById('checkoutChange');
  const btnClearCart = document.getElementById('btnClearCart');
  const posForm = document.getElementById('posForm');
  const checkoutModal = document.getElementById('checkoutModal');
  const quickRfc = document.getElementById('quickRfcInput');
  const quickCp = document.getElementById('quickCpInput');
  const satMsg = document.getElementById('quickSatValidation');
  const quickRequiresInvoice = document.getElementById('quickRequiresInvoice');
  const quickInvoiceFields = document.getElementById('quickInvoiceFields');

  function syncAuth() {
    const method = payment?.value || 'Cash';
    if (auth) {
      auth.required = (method === 'Card' || method === 'Transfer');
      auth.placeholder = method === 'Card'
        ? 'Número de autorización de tarjeta'
        : method === 'Transfer'
          ? 'Referencia de transferencia'
          : 'Tarjeta: autorización / Transferencia: referencia';
    }
    if (amountReceived) {
      amountReceived.disabled = method !== 'Cash';
      if (method !== 'Cash') {
        amountReceived.value = '0';
      }
    }
    syncCheckoutTotals();
  }

  function syncCheckoutTotals() {
    const total = parseFloat(posForm?.dataset.currentTotal || '0') || 0;
    const change = parseFloat(posForm?.dataset.currentChange || '0') || 0;
    const money = (v) => {
      const symbol = posForm?.dataset.currency || '$';
      return `${symbol}${Number(v || 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    };
    if (checkoutTotal) checkoutTotal.textContent = money(total);
    if (checkoutChange) checkoutChange.textContent = money(change);
  }

  checkoutModal?.addEventListener('shown.bs.modal', () => {
    syncCheckoutTotals();
    syncAuth();
  });

  amountReceived?.addEventListener('input', syncCheckoutTotals);
  globalDiscountPercent?.addEventListener('input', syncCheckoutTotals);
  pricesIncludeTax?.addEventListener('change', syncCheckoutTotals);

  payment?.addEventListener('change', syncAuth);
  syncAuth();

  function syncQuickInvoice() {
    const required = !!quickRequiresInvoice?.checked;
    if (quickInvoiceFields) quickInvoiceFields.style.display = required ? 'flex' : 'none';
    if (quickRfc) quickRfc.required = required;
    if (quickCp) quickCp.required = required;
    if (satMsg && !required) {
      satMsg.className = 'text-muted small';
      satMsg.textContent = 'Sin factura: se usará RFC genérico de público en general.';
    }
  }
  quickRequiresInvoice?.addEventListener('change', syncQuickInvoice);

  function satQuickValidate() {
    if (!satMsg) return;
    const rfc = (quickRfc?.value || '').trim().toUpperCase();
    const cp = (quickCp?.value || '').trim();
    const required = !!quickRequiresInvoice?.checked;
    if (!required) {
      satMsg.className = 'text-muted small';
      satMsg.textContent = 'Sin factura: se usará RFC genérico de público en general.';
      return;
    }
    const rfcOk = !rfc || /^[A-Z&Ñ]{3,4}\d{6}[A-Z0-9]{3}$/.test(rfc);
    const cpOk = !cp || /^\d{5}$/.test(cp);
    satMsg.className = (rfcOk && cpOk) ? 'text-success small' : 'text-danger small';
    satMsg.textContent = (rfcOk && cpOk)
      ? 'Validación SAT en vivo: RFC y código postal correctos.'
      : 'Validación SAT: revisa RFC (formato SAT) y código postal de 5 dígitos.';
  }
  quickRfc?.addEventListener('input', satQuickValidate);
  quickCp?.addEventListener('input', satQuickValidate);
  syncQuickInvoice();
  satQuickValidate();

  btnClearCart?.addEventListener('click', () => {
    document.querySelectorAll('.qty-input').forEach((el) => el.value = '0');
    document.querySelectorAll('.line-discount-input').forEach((el) => el.value = '0');
    if (globalDiscountPercent) globalDiscountPercent.value = '0';
    if (amountReceived) amountReceived.value = '0';
    const search = document.getElementById('productSearch');
    if (search) search.value = '';
    document.querySelectorAll('.product-card[data-product-id]').forEach((card) => {
      card.style.display = 'block';
    });
    if (typeof window.dispatchEvent === 'function') {
      window.dispatchEvent(new Event('pos-refresh'));
    }
  });
})();
</script>
}

