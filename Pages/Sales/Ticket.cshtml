@page "{id:int}"
@model HN_Nexus.WebPOS.Pages.Sales.TicketModel
@{
    if (Model.Embed)
    {
        Layout = null;
    }

    ViewData["Title"] = "Ticket";
    var symbol = string.IsNullOrWhiteSpace(Model.Config.CurrencySymbol) ? "$" : Model.Config.CurrencySymbol;
    string money(decimal val) => $"{symbol}{val:N2}";
}

@if (Model.Sale != null)
{
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            <div class="panel" id="ticketPanel">
                <div class="panel-body">
                    <div class="ticket-preview thermal-ticket">
                        <h4 class="text-center mb-1">@Model.Config.CompanyName</h4>
                        <p class="text-center small mb-1">@Model.Config.Address</p>
                        <p class="text-center small mb-1">RFC: @Model.Config.TaxId</p>
                        <p class="text-center small mb-2">Tel: @Model.Config.Phone</p>

                        @if (!string.IsNullOrWhiteSpace(Model.Config.TicketHeader))
                        {
                            <p class="text-center fw-semibold">@Model.Config.TicketHeader</p>
                        }

                        <hr />
                        <div class="ticket-row"><span>Folio</span><strong>#@Model.Sale.Id</strong></div>
                        <div class="ticket-row"><span>Fecha</span><strong>@Model.Sale.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong></div>
                        <div class="ticket-row"><span>Sucursal</span><strong>@Model.Sale.Branch?.Name</strong></div>
                        <div class="ticket-row"><span>Cliente</span><strong>@(Model.Sale.Customer?.FullName ?? "Público General")</strong></div>
                        <div class="ticket-row"><span>Cajero</span><strong>@Model.Sale.User?.FullName</strong></div>
                        <div class="ticket-row"><span>Pago</span><strong>@Model.Sale.PaymentMethod</strong></div>
                        @if (!string.IsNullOrWhiteSpace(Model.Sale.AuthorizationCode))
                        {
                            <div class="ticket-row"><span>Autorización</span><strong>@Model.Sale.AuthorizationCode</strong></div>
                        }
                        <div class="ticket-row"><span>IVA en precio</span><strong>@(Model.Sale.PricesIncludeTax ? "Sí" : "No")</strong></div>

                        <hr />
                        @foreach (var d in Model.Sale.Details)
                        {
                            <div class="ticket-row">
                                <span>@d.Product?.Name x @d.Quantity</span>
                                <strong>@money(d.Total)</strong>
                            </div>
                        }
                        <hr />

                        <div class="ticket-row"><span>Subtotal</span><strong>@money(Model.Sale.SubtotalAmount)</strong></div>
                        <div class="ticket-row"><span>Descuento</span><strong>@money(Model.Sale.DiscountAmount)</strong></div>
                        <div class="ticket-row"><span>IVA</span><strong>@money(Model.Sale.TaxAmount)</strong></div>
                        <div class="ticket-row ticket-total"><span>TOTAL</span><span>@money(Model.Sale.TotalAmount)</span></div>
                        <div class="ticket-row"><span>Recibido</span><strong>@money(Model.Sale.AmountReceived)</strong></div>
                        <div class="ticket-row"><span>Cambio</span><strong>@money(Model.Sale.ChangeAmount)</strong></div>

                        @if (!string.IsNullOrWhiteSpace(Model.Config.TicketFooter))
                        {
                            <p class="text-center mt-3">@Model.Config.TicketFooter</p>
                        }
                    </div>

                    <div class="d-grid gap-2 mt-3 d-print-none">
                        @if (Model.Embed)
                        {
                            <button type="button" class="btn btn-primary" id="btnPrintAndClose">Imprimir ticket</button>
                            <button type="button" class="btn btn-outline-primary" id="btnBackAndClose">Volver a ventas</button>
                        }
                        else
                        {
                            <button class="btn btn-primary" onclick="window.print()">Imprimir ticket</button>
                            <a class="btn btn-outline-primary" asp-page="/Sales/Index">Volver a ventas</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
@if (Model.Embed)
{
<script>
(() => {
  const closeModal = () => window.parent?.postMessage({ type: 'closeTicketModal' }, '*');
  document.getElementById('btnBackAndClose')?.addEventListener('click', closeModal);
  document.getElementById('btnPrintAndClose')?.addEventListener('click', () => {
    window.print();
    setTimeout(closeModal, 400);
  });
})();
</script>
}
<style>
@@media print {
  body { background: #fff !important; margin: 0; }
  .app-sidebar, .app-topbar, .d-print-none { display: none !important; }
  .app-main { padding: 0 !important; }
  .thermal-ticket { width: 80mm; margin: 0 auto; font-size: 12px; }
}
</style>
}

