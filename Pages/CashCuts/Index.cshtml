@page
@model HN_Nexus.WebPOS.Pages.CashCuts.IndexModel
@{
    ViewData["Title"] = "Corte";
}

<section class="panel mb-3">
    <div class="panel-header">
        <div>
            <h5 class="mb-0">Nuevo Corte Diario</h5>
            <small class="text-muted">Consolidado por método de pago</small>
        </div>
    </div>
    <div class="panel-body">
        <div class="row g-2 mb-3">
            <div class="col-md-3"><div class="kpi-card glass-card kpi-gradient kpi-green"><div class="kpi-title">Efectivo</div><div class="kpi-value text-success">@Model.SuggestedCashTotal.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card glass-card kpi-gradient kpi-blue"><div class="kpi-title">Tarjeta</div><div class="kpi-value text-primary">@Model.SuggestedCardTotal.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card glass-card kpi-gradient kpi-cyan"><div class="kpi-title">Transferencia</div><div class="kpi-value text-info">@Model.SuggestedTransferTotal.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card glass-card kpi-gradient kpi-slate"><div class="kpi-title">Total Sistema</div><div class="kpi-value text-dark">@Model.SuggestedSystemTotal.ToString("C")</div></div></div>
        </div>

        <form method="get" class="row g-2 mb-3"><div class="col-md-4"><label class="form-label">Sucursal</label><select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select></div><div class="col-md-2 d-flex align-items-end"><button class="btn btn-outline-primary w-100">Filtrar</button></div></form><form method="post" asp-page-handler="Create" class="row g-3"><input type="hidden" asp-for="BranchId" />
            <div class="col-md-4">
                <label class="form-label">Total físico contado</label>
                <input class="form-control" type="number" step="0.01" name="totalPhysical" required />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-save w-100">Guardar corte</button>
            </div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Historial de Cortes</h5></div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">@item.CutDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge-soft @(item.Difference >= 0 ? "badge-ok" : "badge-danger")">@item.Difference.ToString("C")</span>
                    </div>
                    <div class="fw-semibold mb-1">@item.Branch?.Name</div>
                    <div class="d-flex gap-1 flex-wrap mb-2">
                        <span class="badge-soft badge-info">Sistema @item.TotalSystem.ToString("C")</span>
                        <span class="badge-soft badge-ok">Efectivo @item.CashSales.ToString("C")</span>
                        <span class="badge-soft badge-info">Tarjeta @item.CardSales.ToString("C")</span>
                        <span class="badge-soft badge-warn">Transfer @item.TransferSales.ToString("C")</span>
                    </div>
                    <div class="product-meta">Fisico: @item.TotalPhysical.ToString("C")</div>
                    <div class="product-meta">Usuario: @item.User</div>
                </article>
            }
        </div>
    </div>
</section>


