@page
@model HN_Nexus.WebPOS.Pages.CashCuts.AccountingCloseModel
@{
    ViewData["Title"] = "Cierre Contable";
    var closed = Model.Items.Count(x => x.Status == "Closed");
    var reopened = Model.Items.Count(x => x.Status == "Reopened");
}

<section class="panel mb-3">
    <div class="panel-body">
        <div class="cards-grid compact">
            <div class="kpi-card glass-card kpi-gradient kpi-red"><div class="kpi-title">Cierres activos</div><div class="kpi-value text-danger">@closed</div><span class="badge-soft badge-danger">Bloqueados</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-green"><div class="kpi-title">Reaperturas</div><div class="kpi-value text-success">@reopened</div><span class="badge-soft badge-ok">Auditadas</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-blue"><div class="kpi-title">Total movimientos</div><div class="kpi-value text-primary">@Model.Items.Count</div><span class="badge-soft badge-info">Historico</span></div>
        </div>
    </div>
</section>

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Bloqueo contable por turno/sucursal</h5>
    </div>
    <div class="panel-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4">
                <label class="form-label">Sucursal</label>
                <select asp-for="BranchId" asp-items="Model.Branches" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha</label>
                <input asp-for="Date" type="date" class="form-control" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100">Filtrar</button>
            </div>
        </form>

        <form method="post" asp-page-handler="Close" class="row g-2">
            <input type="hidden" name="branchId" value="@Model.BranchId" />
            <input type="hidden" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
            <div class="col-md-8">
                <input name="notes" class="form-control" placeholder="Notas de cierre (opcional)" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-save w-100">Aplicar cierre contable</button>
            </div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h5 class="mb-0">Historial de cierres / reaperturas</h5>
    </div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">@item.ClosureDate.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        <span class="badge-soft @(item.Status == "Closed" ? "badge-danger" : "badge-ok")">@item.Status</span>
                    </div>
                    <div class="fw-semibold mb-1">@item.Branch?.Name</div>
                    <div class="product-meta">Cerrado por @item.ClosedByUser?.FullName (@item.ClosedAt.ToLocalTime().ToString("dd/MM HH:mm"))</div>
                    @if (item.ReopenedAt.HasValue)
                    {
                        <div class="mt-2"><span class="badge-soft badge-ok">Reabierto por @item.ReopenedByUser?.FullName</span></div>
                        <div class="product-meta">@item.ReopenedAt.Value.ToLocalTime().ToString("dd/MM HH:mm") - @item.ReopenReason</div>
                    }
                    @if (item.Status == "Closed")
                    {
                        <form method="post" asp-page-handler="Reopen" class="reopen-form mt-2">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="branchId" value="@Model.BranchId" />
                            <input type="hidden" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="reason" class="reopen-reason" />
                            <button class="btn btn-sm btn-outline-danger">Reabrir</button>
                        </form>
                    }
                </article>
            }
        </div>
    </div>
</section>

@section Scripts {
<script>
document.querySelectorAll('.reopen-form').forEach(function(form){
  form.addEventListener('submit', function(e){
    var reason = prompt('Motivo de reapertura auditada:');
    if(reason === null){ e.preventDefault(); return; }
    form.querySelector('.reopen-reason').value = reason;
  });
});
</script>
}
