@page
@model HN_Nexus.WebPOS.Pages.Help.IndexModel
@{
    ViewData["Title"] = "Centro de Ayuda";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Centro de ayuda y tutoriales</h5></div>
    <div class="panel-body">
        <div class="cards-grid compact">
            <article class="product-card"><span class="badge-soft badge-info">Tutorial</span><h6 class="mt-2">Venta rápida con escáner</h6><p class="product-meta">Usa F8 para escáner, Enter agrega al carrito y Ctrl+Enter para cobrar.</p></article>
            <article class="product-card"><span class="badge-soft badge-ok">Tutorial</span><h6 class="mt-2">Devolución con aprobación</h6><p class="product-meta">Solicita devolución, aprueba supervisor con firma digital y aplica inventario.</p></article>
            <article class="product-card"><span class="badge-soft badge-warn">Tutorial</span><h6 class="mt-2">Multi-tenant</h6><p class="product-meta">Crea tenant en Configuración/Tenants y asigna usuarios por tenant.</p></article>
            <article class="product-card"><span class="badge-soft badge-danger">Soporte</span><h6 class="mt-2">Incidentes</h6><p class="product-meta">Revisa Monitoreo para errores/latencia y usa correo de prueba SMTP.</p></article>
        </div>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Soporte dentro de la app</h5></div>
    <div class="panel-body row g-2">
        <div class="col-md-6">
            <label class="form-label">Email soporte</label>
            <input class="form-control" value="soporte@hubnet-solutions.net" readonly />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <a class="btn btn-primary w-100" href="https://hubnet-solutions.net" target="_blank" rel="noopener noreferrer">Abrir portal de soporte</a>
        </div>
        <div class="col-12">
            <div class="alert app-alert mb-0">Tip: adjunta folio de venta, sucursal y hora para atención más rápida.</div>
        </div>
    </div>
</section>
