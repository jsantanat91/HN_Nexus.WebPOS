@page
@model HN_Nexus.WebPOS.Pages.Help.IndexModel
@{
    ViewData["Title"] = "Centro de Ayuda";
    var supportMail = "soporte@hubnet-solutions.net";
    var subject = Uri.EscapeDataString("Soporte HN Nexus POS");
    var bodyText = "Hola soporte,\r\n\r\nComparto detalle de mi incidencia:\r\n- Tenant:\r\n- Sucursal:\r\n- Usuario:\r\n- Folio (si aplica):\r\n- Fecha/hora:\r\n- Descripción:\r\n";
    var body = Uri.EscapeDataString(bodyText);
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Centro de ayuda y tutoriales</h5></div>
    <div class="panel-body">
        <div class="cards-grid compact">
            <article class="product-card">
                <span class="badge-soft badge-info">Caja</span>
                <h6 class="mt-2">Venta rápida con escáner</h6>
                <p class="product-meta">Usa F8 para escáner, Enter agrega al carrito y Ctrl+Enter para cobrar.</p>
            </article>
            <article class="product-card">
                <span class="badge-soft badge-ok">Caja</span>
                <h6 class="mt-2">Flujo de cobro y ticket</h6>
                <p class="product-meta">Finaliza venta, selecciona método de pago y elige ticket físico o digital por correo.</p>
            </article>
            <article class="product-card">
                <span class="badge-soft badge-warn">Operación</span>
                <h6 class="mt-2">Turno/corte obligatorio</h6>
                <p class="product-meta">No hay venta sin turno abierto. Cierra turno y corte diario para cambio de día.</p>
            </article>
            <article class="product-card">
                <span class="badge-soft badge-danger">CFDI</span>
                <h6 class="mt-2">Contingencia de timbrado</h6>
                <p class="product-meta">Si PAC falla, revisa Cola CFDI y reintentos automáticos en Configuración.</p>
            </article>
            <article class="product-card">
                <span class="badge-soft badge-info">Inventario</span>
                <h6 class="mt-2">Kardex y transferencias</h6>
                <p class="product-meta">Consulta trazabilidad por movimiento y exporta kardex para auditoría.</p>
            </article>
            <article class="product-card">
                <span class="badge-soft badge-ok">Seguridad</span>
                <h6 class="mt-2">Tenants y permisos</h6>
                <p class="product-meta">Cada tenant ve solo su información. SuperUser administra comparativos globales.</p>
            </article>
        </div>
    </div>
</section>

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Guías rápidas</h5></div>
    <div class="panel-body">
        <div class="row g-2">
            <div class="col-md-4"><div class="alert app-alert mb-0"><strong>1.</strong> Configura negocio, cuentas y SMTP en <strong>Configuración General</strong>.</div></div>
            <div class="col-md-4"><div class="alert app-alert mb-0"><strong>2.</strong> Crea sucursales, almacenes y usuarios con permisos por tenant.</div></div>
            <div class="col-md-4"><div class="alert app-alert mb-0"><strong>3.</strong> Abre turno, vende, corta caja y revisa reportes del mes en curso.</div></div>
        </div>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Soporte por correo</h5></div>
    <div class="panel-body row g-2">
        <div class="col-md-6">
            <label class="form-label">Correo de soporte</label>
            <input class="form-control" value="@supportMail" readonly />
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <a class="btn btn-primary w-100" href="mailto:@supportMail?subject=@subject&body=@body">Enviar correo de soporte</a>
        </div>
        <div class="col-12">
            <div class="alert app-alert mb-0">Incluye tenant, sucursal, usuario, folio y hora para atención más rápida.</div>
        </div>
    </div>
</section>
