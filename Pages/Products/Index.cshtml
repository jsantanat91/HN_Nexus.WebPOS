@page
@model HN_Nexus.WebPOS.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Inventario de Productos";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h5 class="mb-0">Inventario</h5>
            <small class="text-muted">Catalogo principal de productos</small>
        </div>
        <a class="btn btn-primary" asp-page="/Products/New">+ Nuevo producto</a>
    </div>

    <div class="panel-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4"><input class="form-control" name="q" value="@Model.Q" placeholder="Buscar por nombre o codigo" /></div>
            <div class="col-auto"><button class="btn btn-outline-primary">Buscar</button></div>
        </form>
    </div>

    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead><tr><th>Producto</th><th>Codigo</th><th>Categoria</th><th>Stock</th><th>Precio</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.Barcode</td>
                    <td>@item.Category?.Name</td>
                    <td><span class="badge-soft @(item.Stock <= 5 ? "badge-danger" : "badge-ok")">@item.Stock</span></td>
                    <td class="fw-bold">@item.Price.ToString("C")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
