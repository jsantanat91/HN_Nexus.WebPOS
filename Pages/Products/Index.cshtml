@page
@model HN_Nexus.WebPOS.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Productos</h3>
    <a class="btn btn-primary" asp-page="/Products/New">Nuevo producto</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4"><input class="form-control" name="q" value="@Model.Q" placeholder="Nombre o codigo" /></div>
    <div class="col-auto"><button class="btn btn-outline-secondary">Buscar</button></div>
</form>

<table class="table table-striped">
    <thead><tr><th>Producto</th><th>Codigo</th><th>Categoria</th><th>Stock</th><th>Precio</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Barcode</td>
            <td>@item.Category?.Name</td>
            <td>@item.Stock</td>
            <td>@item.Price.ToString("C")</td>
        </tr>
    }
    </tbody>
</table>
