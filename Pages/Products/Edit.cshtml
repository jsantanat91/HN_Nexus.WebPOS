@page "{id:int}"
@model HN_Nexus.WebPOS.Pages.Products.EditModel
@{
    ViewData["Title"] = "Editar producto";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h5 class="mb-0">Editar producto</h5>
            <small class="text-muted">Actualiza datos de catálogo e inventario</small>
        </div>
        <span class="badge-soft badge-info">PROD-@Model.Item.ProductNumber.ToString("D6")</span>
    </div>
    <div class="panel-body">
        <form method="post" class="row g-3">
            <input type="hidden" asp-for="Item.Id" />
            <input type="hidden" asp-for="Item.ProductNumber" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="col-md-6">
                <label asp-for="Item.Name" class="form-label">Nombre</label>
                <input asp-for="Item.Name" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Item.Barcode" class="form-label">Código de barras</label>
                <input asp-for="Item.Barcode" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Item.CategoryId" class="form-label">Categoría</label>
                <select asp-for="Item.CategoryId" asp-items="Model.Categories" class="form-select"></select>
            </div>
            <div class="col-md-3">
                <label asp-for="Item.Price" class="form-label">Precio venta</label>
                <input asp-for="Item.Price" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Item.Cost" class="form-label">Costo</label>
                <input asp-for="Item.Cost" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Item.Stock" class="form-label">Stock total</label>
                <input asp-for="Item.Stock" class="form-control" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input class="form-check-input" asp-for="Item.PriceIncludesTax" />
                    <label class="form-check-label" asp-for="Item.PriceIncludesTax">Precio incluye IVA</label>
                </div>
            </div>
            <div class="col-md-3">
                <label asp-for="Item.SatProductCode" class="form-label">Clave SAT producto</label>
                <input asp-for="Item.SatProductCode" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Item.SatUnitCode" class="form-label">Clave SAT unidad</label>
                <input asp-for="Item.SatUnitCode" class="form-control" />
            </div>

            <div class="col-12">
                <button class="btn btn-save" type="submit">Guardar</button>
                <a class="btn btn-cancel" asp-page="/Products/Index">Cancelar</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
