@page
@model HN_Nexus.WebPOS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Acceso";
}

<section class="login-hero">
    <div class="login-overlay"></div>
    <div class="login-content">
        <div class="login-copy">
            <span class="login-chip">Plataforma POS</span>
            <h1>BIENVENIDO A<br />HN NEXUS POS</h1>
            <p>Gestiona caja, inventario, clientes y reportes desde un solo panel moderno.</p>
            <ul>
                <li>Venta r·pida con teclado y esc·ner</li>
                <li>CFDI y ticket tÈrmico en un flujo</li>
                <li>Control por sucursal y roles</li>
            </ul>
        </div>

        <div class="login-panel login-card p-4">
            <h3 class="fw-bold mb-3">INICIAR SESI”N</h3>
            <form method="post">
                <div asp-validation-summary="All" class="text-danger small"></div>

                <div class="mb-3">
                    <label asp-for="Input.Username" class="form-label">Nombre de usuario / correo</label>
                    <input asp-for="Input.Username" class="form-control login-input" autocomplete="username" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">ContraseÒa</label>
                    <input asp-for="Input.Password" type="password" class="form-control login-input" autocomplete="current-password" />
                </div>

                <div class="d-flex justify-content-between align-items-center small mb-3 text-light opacity-75">
                    <span>Acceso seguro</span>
                    <span>HN Nexus</span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Iniciar sesiÛn</button>
            </form>

            <small class="text-light d-block mt-3 text-center opacity-75">Demo inicial: admin / admin123</small>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
