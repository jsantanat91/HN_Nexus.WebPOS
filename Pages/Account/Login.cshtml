@page
@model HN_Nexus.WebPOS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Acceso";
}

<section class="login-hero">
    <div class="login-overlay"></div>
    <div class="login-glow login-glow-a"></div>
    <div class="login-glow login-glow-b"></div>

    <div class="login-content">
        <div class="login-copy">
            <span class="login-chip">Plataforma POS</span>
            <h1>BIENVENIDO A<br />HN NEXUS POS</h1>
            <p>Sistema profesional para caja, inventario, clientes y control multi-sucursal.</p>
            <ul>
                <li>Cobro veloz con teclado, escáner y atajos</li>
                <li>CFDI, ticket térmico y reportes en un flujo</li>
                <li>Operación por roles, permisos y sucursales</li>
            </ul>

            <div class="login-stats">
                <div class="login-stat"><strong>POS</strong><span>Venta ágil</span></div>
                <div class="login-stat"><strong>INV</strong><span>Inventario vivo</span></div>
                <div class="login-stat"><strong>REP</strong><span>Reportes diarios</span></div>
            </div>
        </div>

        <div class="login-panel login-card p-4">
            <h3 class="fw-bold mb-3">INICIAR SESIÓN</h3>
            <form method="post">
                <div asp-validation-summary="All" class="text-danger small"></div>

                <div class="mb-3">
                    <label asp-for="Input.Username" class="form-label">Nombre de usuario / correo</label>
                    <input asp-for="Input.Username" class="form-control login-input" autocomplete="username" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" type="password" class="form-control login-input" autocomplete="current-password" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Iniciar sesión</button>
            </form>

            <div class="login-badges mt-3">
                <span class="login-badge">Acceso seguro</span>
                <span class="login-badge">HN Nexus</span>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
