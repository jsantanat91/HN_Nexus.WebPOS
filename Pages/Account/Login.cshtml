@page
@model HN_Nexus.WebPOS.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Acceso";
}

<section class="login-split-wrap">
    <div class="login-left-pane">
        <div class="login-pro-card">
            <div class="login-brand">HN NEXUS</div>
            <h2>Iniciar sesión</h2>
            <p class="login-muted">Acceso al sistema de punto de venta.</p>
            @if (TempData["Flash"] is string flash && !string.IsNullOrWhiteSpace(flash))
            {
                <div class="alert app-alert py-2 my-2">@flash</div>
            }

            <form method="post" class="mt-3">
                <div asp-validation-summary="All" class="text-danger small"></div>
                <div class="mb-3">
                    <label asp-for="Input.Username" class="form-label">Nombre de usuario / correo</label>
                    <input asp-for="Input.Username" class="form-control" autocomplete="username" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Contraseña</label>
                    <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.TenantCode" class="form-label">Tenant (cliente)</label>
                    <input asp-for="Input.TenantCode" class="form-control" placeholder="ej. principal / acme" />
                    <small class="text-muted">Si eres SuperUser puedes dejarlo vacío.</small>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">Entrar</button>
            </form>
            <button type="button" class="btn btn-link p-0 mt-2 small" data-bs-toggle="collapse" data-bs-target="#recoverBox" aria-expanded="false" aria-controls="recoverBox">
                ¿Olvidaste tu contraseña?
            </button>
            <div class="collapse mt-2" id="recoverBox">
                <form method="post" asp-page-handler="RecoverPassword" class="row g-2">
                    <div class="col-12">
                        <label asp-for="Recovery.UsernameOrEmail" class="form-label">Usuario o correo</label>
                        <input asp-for="Recovery.UsernameOrEmail" class="form-control" placeholder="usuario o correo" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Recovery.TenantCode" class="form-label">Tenant (si aplica)</label>
                        <input asp-for="Recovery.TenantCode" class="form-control" placeholder="ej. principal / acme" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-outline-primary w-100">Enviar recuperación por correo</button>
                    </div>
                </form>
            </div>

            <div class="login-badges mt-3">
                <span class="login-badge">Acceso seguro</span>
                <span class="login-badge">HN Nexus</span>
            </div>
        </div>

        <div class="login-footer-note">
            Punto de Venta v2.0 PRO by
            <a href="https://hubnet-solutions.net" target="_blank" rel="noopener noreferrer">HN Solutions</a>
        </div>
    </div>

    <div class="login-right-pane" aria-hidden="true">
        <div class="login-pos-photo"></div>
        <div class="login-right-overlay">
            <h3>Punto de Venta Inteligente</h3>
            <p>Caja, inventario, clientes, órdenes y reportes en una sola plataforma.</p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
