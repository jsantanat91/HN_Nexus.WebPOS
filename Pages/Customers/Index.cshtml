@page
@model HN_Nexus.WebPOS.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h5 class="mb-0">Listado de Clientes</h5>
            <small class="text-muted">Base comercial y datos de facturacion</small>
        </div>
        <a class="btn btn-primary" asp-page="/Customers/New">+ Nuevo cliente</a>
    </div>

    <div class="panel-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4"><input class="form-control" name="q" value="@Model.Q" placeholder="Nombre, RFC o correo" /></div>
            <div class="col-auto"><button class="btn btn-outline-primary">Buscar</button></div>
        </form>
    </div>

    <div class="panel-body p-0">
        <table class="table table-modern mb-0">
            <thead><tr><th>Nombre</th><th>RFC</th><th>CFDI</th><th>Pago SAT</th><th>Teléfono</th><th>Email</th><th>Estatus</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.FullName</td>
                    <td>@item.Rfc</td>
                    <td><span class="badge-soft badge-info">@item.CfdiUse</span></td>
                    <td><span class="badge-soft badge-warn">@item.PaymentForm / @item.PaymentMethodSat</span></td>
                    <td>@item.PhoneNumber</td>
                    <td>@item.Email</td>
                    <td><span class="badge-soft @(item.IsActive ? "badge-ok" : "badge-danger")">@(item.IsActive ? "Activo" : "Inactivo")</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

