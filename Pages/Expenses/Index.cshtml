@page
@model HN_Nexus.WebPOS.Pages.Expenses.IndexModel
@{
    ViewData["Title"] = "Gastos";
}

<section class="panel mb-3">
    <div class="panel-header"><h5 class="mb-0">Registrar gasto</h5></div>
    <div class="panel-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-4"><input class="form-control" name="description" placeholder="Descripción" /></div>
            <div class="col-md-2"><input class="form-control" type="number" step="0.01" name="amount" placeholder="Monto" /></div>
            <div class="col-md-3"><input class="form-control" name="category" placeholder="Categoría" /></div>
            <div class="col-md-2"><button class="btn btn-save">Guardar</button></div>
        </form>
    </div>
</section>

<section class="panel">
    <div class="panel-header"><h5 class="mb-0">Historial de egresos</h5></div>
    <div class="panel-body">
        <div class="cards-grid">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">@item.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge-soft badge-danger">@item.Amount.ToString("C")</span>
                    </div>
                    <h6 class="mb-1">@item.Description</h6>
                    <div class="product-meta">Categoría:</div>
                    <div><span class="badge-soft category-pill" data-category="@item.Category">@item.Category</span></div>
                </article>
            }
        </div>
    </div>
</section>
