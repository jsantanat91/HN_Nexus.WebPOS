@page
@model HN_Nexus.WebPOS.Pages.Expenses.IndexModel
@{
    ViewData["Title"] = "Gastos";
    var total = Model.Items.Sum(x => x.Amount);
    var categories = Model.Items.Select(x => x.Category).Distinct().Count();
    var today = Model.Items.Where(x => x.Date.ToLocalTime().Date == DateTime.Now.Date).Sum(x => x.Amount);
}

<section class="panel mb-3">
    <div class="panel-header">
        <h5 class="mb-0">Resumen de gastos</h5>
        <button class="btn btn-save" type="button" data-bs-toggle="modal" data-bs-target="#newExpenseModal">Nuevo gasto</button>
    </div>
    <div class="panel-body">
        <div class="cards-grid compact">
            <div class="kpi-card glass-card kpi-gradient kpi-red"><div class="kpi-title">Total egresos</div><div class="kpi-value text-danger">@total.ToString("C")</div><span class="badge-soft badge-danger">Acumulado</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-amber"><div class="kpi-title">Gasto hoy</div><div class="kpi-value text-warning">@today.ToString("C")</div><span class="badge-soft badge-warn">@DateTime.Now.ToString("dd/MM")</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-blue"><div class="kpi-title">Movimientos</div><div class="kpi-value text-primary">@Model.Items.Count</div><span class="badge-soft badge-info">Registros</span></div>
            <div class="kpi-card glass-card kpi-gradient kpi-cyan"><div class="kpi-title">Categorías</div><div class="kpi-value text-info">@categories</div><span class="badge-soft badge-info">Activas</span></div>
        </div>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h5 class="mb-0">Historial de egresos</h5>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm" type="button" id="btnExpenseCards">Cards</button>
            <button class="btn btn-outline-primary btn-sm" type="button" id="btnExpenseTable">Tabla</button>
        </div>
    </div>
    <div class="panel-body">
        <div class="cards-grid" id="expenseCardsView">
            @foreach (var item in Model.Items)
            {
                <article class="product-card">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge-soft badge-info">@item.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge-soft badge-danger">@item.Amount.ToString("C")</span>
                    </div>
                    <h6 class="mb-1">@item.Description</h6>
                    <div class="product-meta mb-1">Categoría</div>
                    <span class="badge-soft category-pill" data-category="@item.Category">@item.Category</span>
                </article>
            }
        </div>
        <div class="table-responsive" id="expenseTableView" style="display:none;">
            <table class="table table-modern mb-0">
                <thead><tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th>Monto</th></tr></thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.Description</td>
                        <td><span class="badge-soft category-pill" data-category="@item.Category">@item.Category</span></td>
                        <td><span class="badge-soft badge-danger">@item.Amount.ToString("C")</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="modal fade" id="newExpenseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Nuevo gasto</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body row g-2">
                    <div class="col-12"><label class="form-label">Descripción</label><input class="form-control" name="description" required /></div>
                    <div class="col-md-6"><label class="form-label">Monto</label><input class="form-control" type="number" step="0.01" name="amount" required /></div>
                    <div class="col-md-6"><label class="form-label">Categoría</label><input class="form-control" name="category" placeholder="Operación, renta, nómina..." /></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-save">Guardar</button></div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
  const cards = document.getElementById('expenseCardsView');
  const table = document.getElementById('expenseTableView');
  document.getElementById('btnExpenseCards')?.addEventListener('click', () => { cards.style.display = 'grid'; table.style.display = 'none'; });
  document.getElementById('btnExpenseTable')?.addEventListener('click', () => { cards.style.display = 'none'; table.style.display = 'block'; });
})();
</script>
}

